<root BTCPP_format="4">

  <BehaviorTree ID="Keypad">
    <Sequence>
      <DriveToPose x="-0.84" y="-0.50" yaw="180" angular_tolerance="2"/>
      <DriveToPose x="-0.84" y="-0.05" yaw="180" linear_tolerance="0.01" angular_tolerance="2"/>
      <Finger idx="7" action="click"/>
      <Finger idx="3" action="click"/>
      <Finger idx="7" action="click"/>
      <Finger idx="3" action="click"/>
      <Finger idx="8" action="click"/>
      <Finger idx="-1" action="click"/>
      <DriveToPose x="-0.84" y="-0.50" yaw="0"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Button">
    <Sequence>
      <DriveToPose x="0.0" y="-0.50" yaw="0"/>
      <DriveToPose x="0.0" y="-0.90" yaw="0"/>
      <Finger idx="8" action="click"/>
      <Finger idx="8" action="click"/>
      <Finger idx="8" action="click"/>
      <DriveToPose x="0.0" y="-0.50" yaw="0"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Full">
    <Sequence>
      <SubTree ID="WaitForStart"/>
      <SubTree ID="Keypad"/>
      <SubTree ID="Button"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="WaitForStart">
    <Parallel success_count="1" failure_count="-1">
      <Start action_name="/start_button"/>
      <Start action_name="/start_light"/>
    </Parallel>
  </BehaviorTree>

</root>
